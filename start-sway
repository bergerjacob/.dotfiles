#!/bin/bash

# === NVIDIA + Sway required vars ===
export GBM_BACKEND=nvidia-drm
export __GLX_VENDOR_LIBRARY_NAME=nvidia

# === Disable VRR/G-SYNC — prevents refresh rate floor lock ===
export __GL_GSYNC_ALLOWED=0
export __GL_VRR_ALLOWED=0

# === Disable hardware cursors (already needed for NVIDIA) ===
export WLR_NO_HARDWARE_CURSORS=1

# === Explicit sync ===
# NOTE: WLR_RENDER_NO_EXPLICIT_SYNC=1 was removed — it breaks PipeWire screencast
# on NVIDIA 555+. Explicit sync is now required for DMA-BUF sharing.
# If you see tearing, try: export WLR_RENDER_NO_EXPLICIT_SYNC=1

# XDG data directories (must include standard paths + flatpak)
export XDG_DATA_DIRS="/usr/local/share:/usr/share:/var/lib/flatpak/exports/share:$HOME/.local/share/flatpak/exports/share"

# Needed for zoom
export XDG_CURRENT_DESKTOP=sway
MOZ_ENABLE_WAYLAND=1 firefox

# Launch Sway
sway --unsupported-gpu
