{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "orchestrator",
  "instructions": [
    "./delegation-guidelines.md"
  ],
  "experimental": {
    "batch_tool": true
  },
  "permission": {
    "webfetch": "allow"
  },
  "mcp": {
    "mailchimp": {
      "type": "local",
      "command": ["uvx", "mailchimp-mcp"],
      "enabled": true,
      "environment": {
        "MAILCHIMP_API_KEY": "{env:MAILCHIMP_API_KEY}",
        "MAILCHIMP_TOOLS": "list_campaigns,get_campaign_details,replicate_campaign,set_campaign_content,update_campaign,send_test_email,list_templates,get_template,get_template_default_content,create_template,update_template,list_automations,get_automation_emails,describe_tools"
      }
    }
  },
  "provider": {
    "local-server": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Local Qwen",
      "options": {
        "baseURL": "http://127.0.0.1:8088/v1",
        "apiKey": "not-required"
      },
      "models": {
        "/tmp/bergejac/models/models--Qwen--Qwen3.5-27B-FP8/snapshots/2e1b21350ce589fcaafbb3c7d7eac526a7aed582": {
          "name": "Qwen3.5 27b (Local)"
        },
        "/tmp/bergejac/models/models--Intel--Qwen3.5-122B-A10B-int4-AutoRound/snapshots/bfac534d4d8742dd15e46f7efdf73336b0213970": {
          "name": "Qwen3.5 122b (Local)"
        }
      }
    }
  },
  "plugin": [
    "@tarquinen/opencode-dcp@latest",
    "oh-my-opencode-slim"
  ],
  "agent": {
    "build": {
      "disable": true
    },
    "plan": {
      "disable": true
    },
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    },
    "doer": {
      "description": "General-purpose coding agent. Pick a model, give instructions, get results. No delegation, no complexity.",
      "model": "neuralwatt/glm-5.2",
      "permission": {
        "read": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "lsp": "allow",
        "skill": "allow",
        "question": "allow",
        "todowrite": "allow",
        "task": "deny",
        "external_directory": "allow"
      }
    },
    "fullcontrol": {
      "mode": "primary",
      "permission": {
        "read": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "lsp": "allow",
        "skill": "allow",
        "question": "allow",
        "todowrite": "allow",
        "task": "allow",
        "external_directory": "allow"
      }
    }
  },
  "lsp": true
}
